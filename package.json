{
  "name": "pomelo",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "start": "turbo run start",
    "dev": "pnpm --filter @pomelo/code-gen build && turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "ts-node": "^10.9.2",
    "turbo": "^2.8.20",
    "typescript": "^6.0.2"
  },
  "engines": {
    "npm": "Use pnpm",
    "yarn": "Use pnpm",
    "pnpm": ">=10.0.0"
  }
}
